// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "redact_private_values": true,
  "cli_default_open_behavior": "new_window",
  "agent_servers": {
    "github-copilot-cli": {
      "type": "registry",
    },
    "cursor": {
      "type": "registry",
    },
    "claude-acp": {
      "type": "registry",
    },
  },
  "collaboration_panel": {
    "dock": "right",
  },
  "git_panel": {
    "dock": "left",
  },
  "edit_predictions": {
    "provider": "copilot",
  },
  "ui_font_weight": 250.0,
  "ui_font_family": "Dank Mono",
  "agent": {
    "show_turn_stats": true,
    "message_editor_min_lines": 6,
    "dock": "right",
    "default_profile": "plan",
    "profiles": {
      "plan": {
        "name": "plan",
        "tools": {},
        "enable_all_context_servers": false,
        "context_servers": {},
      },
    },
    "inline_assistant_model": {
      "provider": "copilot_chat",
      "model": "claude-sonnet-4.5",
    },
    "default_model": {
      "enable_thinking": false,
      "provider": "copilot_chat",
      "model": "claude-sonnet-4.5",
    },
    "favorite_models": [
      {
        "provider": "copilot_chat",
        "model": "claude-sonnet-4.5",
        "enable_thinking": false,
      },
    ],
    "model_parameters": [],
  },
  "outline_panel": {
    "dock": "right",
    "git_status": false,
  },
  "base_keymap": "VSCode",
  // "status_bar": {
  //     "experimental.show": false,
  // },
  "tab_bar": {
    "show": true,
  },
  "tabs": {
    "git_status": false,
  },
  "show_signature_help_after_edits": false,
  "auto_signature_help": false,
  "multi_cursor_modifier": "cmd_or_ctrl",
  "cursor_shape": "block",
  "cursor_blink": false,
  "drag_and_drop_selection": {
    "enabled": false,
  },
  "sticky_scroll": {
    "enabled": false,
  },
  "gutter": {
    "line_numbers": true,
    "folds": false,
    "min_line_number_digits": 0,
    "runnables": false,
  },
  "minimap": {
    "show": "never",
  },
  "scrollbar": {
    "axes": {
      "horizontal": false,
      "vertical": true,
    },
  },
  "hover_popover_delay": 300,
  "selection_highlight": false,

  "show_completions_on_input": true,
  "show_whitespaces": "none",
  "ensure_final_newline_on_save": true,
  "indent_guides": {
    "enabled": false,
  },
  "tab_size": 2,
  "terminal": {
    "max_scroll_history_lines": 1000000,
    "line_height": {
      "custom": 2.0,
    },
    "cursor_shape": "block",
    "working_directory": "always_home",
    "detect_venv": {
      "on": {
        "directories": [".env", "env", ".venv", "venv"],
        "activate_script": "default",
      },
    },
    "font_family": "FiraCode Nerd Font Mono",
    "font_size": 14.0,
    "toolbar": {
      "breadcrumbs": true,
    },
    "copy_on_select": true,
    "font_weight": 250.0,
    "shell": "system",
    "keep_selection_on_copy": true,
    "dock": "bottom",
    "default_width": 440,
    "default_height": 500,
  },
  "prettier": {
    "allowed": true,
  },
  "which_key": {
    "enabled": false,
  },
  "format_on_save": "on",
  "autosave": "on_focus_change",
  "restore_on_startup": "empty_tab",
  "session": {
    "trust_all_worktrees": true,
  },
  "buffer_line_height": {
    "custom": 2,
  },
  "agent_ui_font_size": 17.0,
  "agent_buffer_font_size": 15.0,
  "buffer_font_weight": 250.0,
  "buffer_font_family": "JetBrainsMono Nerd Font",
  "icon_theme": {
    "mode": "system",
    "light": "Zed (Default)",
    "dark": "Material Icon Theme",
  },
  "snippet_sort_order": "top",
  "ui_font_size": 17.0,
  "buffer_font_size": 14.0,
  "theme": {
    "mode": "dark",
    "light": "One Light",
    "dark": "One Dark Pro",
  },
  "title_bar": {
    "show_onboarding_banner": false,
    "show_project_items": false,
    "show_branch_name": false,
    "show_user_menu": false,
  },
  "toolbar": {
    "quick_actions": false,
  },
  "project_panel": {
    "dock": "right",
    "default_width": 350,
    "hide_root": true,
    "auto_fold_dirs": false,
    "starts_open": false,
    "git_status": true,
    "sticky_scroll": false,
    "sort_mode": "directories_first",
    "drag_and_drop": true,
    "show_diagnostics": "all",
    "indent_size": 35,
    "entry_spacing": "comfortable",
    "scrollbar": {
      "show": "never",
    },
    "indent_guides": {
      "show": "never",
    },
  },
  "file_finder": {
    "modal_max_width": "large",
  },
  "extend_comment_on_newline": false,
  "horizontal_scroll_margin": 5,
  "vertical_scroll_margin": 10,
  "close_on_file_delete": true,
  "git": {
    "git_gutter": "tracked_files",
    "inline_blame": {
      "enabled": false,
    },
  },
  "file_types": {
    "Ansible": [
      "**.ansible.yml",
      "**.ansible.yaml",
      "**/defaults/*.yml",
      "**/defaults/*.yaml",
      "**/meta/*.yml",
      "**/meta/*.yaml",
      "**/tasks/*.yml",
      "**/tasks/*.yaml",
      "**/handlers/*.yml",
      "**/handlers/*.yaml",
      "**/group_vars/*.yml",
      "**/group_vars/*.yaml",
      "**/playbooks/*.yaml",
      "**/playbooks/*.yml",
      "**playbook*.yaml",
      "**playbook*.yml",
      "**pb_*.yml",
    ],
  },
  "languages": {
    "YAML": {
      "formatter": "language_server",
      "tab_size": 2,
    },
    "Python": {
      "format_on_save": "on",
      "code_actions_on_format": {
        // Organize imports
        "source.organizeImports.ruff": true,
        // Fix all auto-fixable lint violations
        "source.fixAll.ruff": true,
      },
      "language_servers": [
        // Disable basedpyright and enable ty, and otherwise
        // use the default configuration.
        "ty",
        "!basedpyright",
        "...",
      ],
    },
  },
  "lsp": {
    "yaml-language-server": {
      "settings": {
        "yaml": {
          "keyOrdering": false, // Enforces alphabetical ordering of keys in maps
          "customTags": [
            "!Ref scalar",
            "!Sub scalar",
            "!Sub sequence",
            "!GetAtt scalar",
            "!GetAtt sequence",
            "!Join sequence",
            "!FindInMap sequence",
            "!Select sequence",
            "!Split sequence",
            "!If sequence",
            "!Equals sequence",
            "!And sequence",
            "!Or sequence",
            "!Not sequence",
            "!ImportValue scalar",
            "!ImportValue sequence",
            "!Base64 scalar",
            "!Base64 sequence",
            "!Cidr sequence",
            "!Transform mapping",
          ],
        },
        "format": {
          "singleQuote": true,
        },
        "customTags": ["!And scalar"],
      },
    },
    "ruff": {
      "initialization_options": {
        "settings": {
          // Ruff server settings go here
          "lineLength": 160,
          "lint": {
            "extendSelect": ["I"],
          },
        },
      },
    },
    "terraform-ls": {
      "initialization_options": {
        "experimentalFeatures": {
          "prefillRequiredFields": true,
        },
      },
    },
    // Note, the Zed Ansible extension prefixes all settings with `ansible`
    // so instead of using `ansible.ansible.path` use `ansible.path`.
    "ansible": {
      "settings": {
        "ansible": {
          "path": "ansible",
        },
        "executionEnvironment": {
          "enabled": true,
          "fileAssociations": {
            "*.yml": "ansible",
          },
        },
        "python": {
          "interpreterPath": "python3",
        },
        "validation": {
          "enabled": false, // disable validation
          "lint": {
            "enabled": false, // disable ansible-lint
            "path": "ansible-lint",
          },
        },
      },
    },
  },
}
