// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  // ---------------------------------------------------------------------------
  // General / App
  // ---------------------------------------------------------------------------
  "base_keymap": "VSCode",
  "cli_default_open_behavior": "new_window",
  "redact_private_values": true,
  "restore_on_startup": "empty_tab",
  "session": {
    "trust_all_worktrees": true,
  },
  "which_key": {
    "enabled": false,
  },

  // ---------------------------------------------------------------------------
  // Theme & Appearance
  // ---------------------------------------------------------------------------
  "theme": {
    "mode": "dark",
    "light": "One Light",
    "dark": "One Dark Pro",
  },
  "icon_theme": {
    "mode": "system",
    "light": "Zed (Default)",
    "dark": "Material Icon Theme",
  },

  // ---------------------------------------------------------------------------
  // UI
  // ---------------------------------------------------------------------------
  "ui_font_family": "Dank Mono",
  "ui_font_size": 17.0,
  "ui_font_weight": 250.0,
  "title_bar": {
    "show_onboarding_banner": false,
    "show_project_items": false,
    "show_branch_name": false,
    "show_user_menu": false,
  },

  // ---------------------------------------------------------------------------
  // Buffer / Editor
  // ---------------------------------------------------------------------------
  "buffer_font_family": "Dank Mono",
  "buffer_font_size": 14.5,
  "buffer_font_weight": 250.0,
  "buffer_line_height": {
    "custom": 2,
  },
  "tab_size": 2,
  "cursor_shape": "block",
  "cursor_blink": false,
  "multi_cursor_modifier": "cmd_or_ctrl",
  "drag_and_drop_selection": {
    "enabled": false,
  },
  "selection_highlight": false,
  "hover_popover_delay": 300,
  "show_completions_on_input": true,
  "show_signature_help_after_edits": false,
  "auto_signature_help": false,
  "show_whitespaces": "none",
  "extend_comment_on_newline": false,
  "snippet_sort_order": "top",
  "close_on_file_delete": true,
  "gutter": {
    "line_numbers": true,
    "folds": false,
    "min_line_number_digits": 0,
    "runnables": false,
  },
  "indent_guides": {
    "enabled": false,
  },

  // ---------------------------------------------------------------------------
  // Scrolling
  // ---------------------------------------------------------------------------
  "horizontal_scroll_margin": 5,
  "vertical_scroll_margin": 10,
  "scrollbar": {
    "axes": {
      "horizontal": false,
      "vertical": true,
    },
  },
  "sticky_scroll": {
    "enabled": false,
  },
  "minimap": {
    "show": "never",
  },

  // ---------------------------------------------------------------------------
  // Tabs & Toolbar
  // ---------------------------------------------------------------------------
  "tab_bar": {
    "show": true,
  },
  "tabs": {
    "git_status": false,
  },
  "toolbar": {
    "quick_actions": false,
  },

  // ---------------------------------------------------------------------------
  // Save & Format
  // ---------------------------------------------------------------------------
  "autosave": "on_focus_change",
  "format_on_save": "on",
  "ensure_final_newline_on_save": true,
  "prettier": {
    "allowed": true,
  },

  // ---------------------------------------------------------------------------
  // Git
  // ---------------------------------------------------------------------------
  "git": {
    "git_gutter": "tracked_files",
    "inline_blame": {
      "enabled": false,
    },
  },

  // ---------------------------------------------------------------------------
  // Agent
  // ---------------------------------------------------------------------------
  "agent_ui_font_size": 17.0,
  "agent_buffer_font_size": 15.0,
  "agent": {
    "sidebar_side": "right",
    "dock": "right",
    "show_turn_stats": true,
    "message_editor_min_lines": 6,
    "default_profile": "write",
    "profiles": {
      "plan": {
        "name": "plan",
        "tools": {},
        "enable_all_context_servers": false,
        "context_servers": {},
      },
    },
    "default_model": {
      "provider": "copilot_chat",
      "model": "claude-sonnet-4.6",
      "effort": "high",
      "enable_thinking": true,
    },
    "inline_assistant_model": {
      "provider": "copilot_chat",
      "model": "claude-sonnet-4.5",
    },
    "favorite_models": [
      {
        "provider": "copilot_chat",
        "model": "claude-sonnet-4.5",
        "enable_thinking": false,
      },
    ],
    "model_parameters": [],
  },
  "agent_servers": {
    "gemini": {
      "type": "registry",
    },
    "github-copilot-cli": {
      "type": "registry",
    },
    "cursor": {
      "type": "registry",
    },
    "claude-acp": {
      "type": "registry",
    },
  },
  "edit_predictions": {
    "provider": "copilot",
  },

  // ---------------------------------------------------------------------------
  // Panels
  // ---------------------------------------------------------------------------
  "collaboration_panel": {
    "dock": "left",
  },
  "outline_panel": {
    "dock": "left",
    "git_status": false,
  },
  "project_panel": {
    "dock": "left",
    "default_width": 350,
    "hide_root": true,
    "auto_fold_dirs": false,
    "starts_open": false,
    "git_status": true,
    "sticky_scroll": false,
    "sort_mode": "directories_first",
    "drag_and_drop": true,
    "show_diagnostics": "all",
    "indent_size": 35,
    "entry_spacing": "comfortable",
    "scrollbar": {
      "show": "never",
    },
    "indent_guides": {
      "show": "never",
    },
  },
  "file_finder": {
    "modal_max_width": "large",
  },

  // ---------------------------------------------------------------------------
  // Terminal
  // ---------------------------------------------------------------------------
  "terminal": {
    "font_family": "SauceCodePro Nerd Font Mono",
    "font_size": 14.0,
    "font_weight": 250.0,
    "line_height": {
      "custom": 2.0,
    },
    "cursor_shape": "block",
    "dock": "bottom",
    "default_width": 440,
    "default_height": 500,
    "working_directory": "always_home",
    "shell": "system",
    "max_scroll_history_lines": 1000000,
    "copy_on_select": true,
    "keep_selection_on_copy": true,
    "toolbar": {
      "breadcrumbs": true,
    },
    "detect_venv": {
      "on": {
        "directories": [".env", "env", ".venv", "venv"],
        "activate_script": "default",
      },
    },
  },

  // ---------------------------------------------------------------------------
  // Languages & LSP
  // ---------------------------------------------------------------------------
  "file_types": {
    "Ansible": [
      "**.ansible.yml",
      "**.ansible.yaml",
      "**/defaults/*.yml",
      "**/defaults/*.yaml",
      "**/meta/*.yml",
      "**/meta/*.yaml",
      "**/tasks/*.yml",
      "**/tasks/*.yaml",
      "**/handlers/*.yml",
      "**/handlers/*.yaml",
      "**/group_vars/*.yml",
      "**/group_vars/*.yaml",
      "**/playbooks/*.yaml",
      "**/playbooks/*.yml",
      "**playbook*.yaml",
      "**playbook*.yml",
      "**pb_*.yml",
    ],
  },
  "languages": {
    "YAML": {
      "formatter": "language_server",
      "tab_size": 2,
    },
    "Python": {
      "format_on_save": "on",
      "code_actions_on_format": {
        // Organize imports
        "source.organizeImports.ruff": true,
        // Fix all auto-fixable lint violations
        "source.fixAll.ruff": true,
      },
      "language_servers": [
        // Disable basedpyright and enable ty, and otherwise
        // use the default configuration.
        "ty",
        "!basedpyright",
        "...",
      ],
    },
  },
  "lsp": {
    "yaml-language-server": {
      "settings": {
        "yaml": {
          "keyOrdering": false, // Enforces alphabetical ordering of keys in maps
          "customTags": [
            "!Ref scalar",
            "!Sub scalar",
            "!Sub sequence",
            "!GetAtt scalar",
            "!GetAtt sequence",
            "!Join sequence",
            "!FindInMap sequence",
            "!Select sequence",
            "!Split sequence",
            "!If sequence",
            "!Equals sequence",
            "!And sequence",
            "!Or sequence",
            "!Not sequence",
            "!ImportValue scalar",
            "!ImportValue sequence",
            "!Base64 scalar",
            "!Base64 sequence",
            "!Cidr sequence",
            "!Transform mapping",
          ],
        },
        "format": {
          "singleQuote": true,
        },
        "customTags": ["!And scalar"],
      },
    },
    "ruff": {
      "initialization_options": {
        "settings": {
          // Ruff server settings go here
          "lineLength": 160,
          "lint": {
            "extendSelect": ["I"],
          },
        },
      },
    },
    "terraform-ls": {
      "initialization_options": {
        "experimentalFeatures": {
          "prefillRequiredFields": true,
        },
      },
    },
    // Note, the Zed Ansible extension prefixes all settings with `ansible`
    // so instead of using `ansible.ansible.path` use `ansible.path`.
    "ansible": {
      "settings": {
        "ansible": {
          "path": "ansible",
        },
        "executionEnvironment": {
          "enabled": true,
          "fileAssociations": {
            "*.yml": "ansible",
          },
        },
        "python": {
          "interpreterPath": "python3",
        },
        "validation": {
          "enabled": false, // disable validation
          "lint": {
            "enabled": false, // disable ansible-lint
            "path": "ansible-lint",
          },
        },
      },
    },
  },
}
